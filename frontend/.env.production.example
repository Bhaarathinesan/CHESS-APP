# Production Environment Configuration
# Copy this file to .env.production for production deployment
# IMPORTANT: Use strong secrets and secure credentials

# API Configuration
NEXT_PUBLIC_API_URL=https://api.chessarena.com
NEXT_PUBLIC_WS_URL=https://api.chessarena.com

# Authentication
NEXTAUTH_URL=https://chessarena.com
NEXTAUTH_SECRET=production-nextauth-secret-use-strong-random-value

# OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# Application Configuration
NODE_ENV=production
NEXT_PUBLIC_APP_NAME=ChessArena
NEXT_PUBLIC_APP_URL=https://chessarena.com

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_ENABLE_DEBUG=false

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-upload-preset
