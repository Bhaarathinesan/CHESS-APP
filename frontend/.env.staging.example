# Staging Environment Configuration
# Copy this file to .env.staging for staging deployment

# API Configuration
NEXT_PUBLIC_API_URL=https://api-staging.chessarena.com
NEXT_PUBLIC_WS_URL=https://api-staging.chessarena.com

# Authentication
NEXTAUTH_URL=https://staging.chessarena.com
NEXTAUTH_SECRET=staging-nextauth-secret-change-this

# OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# Application Configuration
NODE_ENV=staging
NEXT_PUBLIC_APP_NAME=ChessArena (Staging)
NEXT_PUBLIC_APP_URL=https://staging.chessarena.com

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_ENABLE_DEBUG=false

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-upload-preset
