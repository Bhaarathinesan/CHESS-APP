# Development Environment Configuration
# Copy this file to .env.development for local development

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/chessarena_dev
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=dev-secret-key-not-for-production
JWT_EXPIRATION=24h
REFRESH_TOKEN_EXPIRATION=30d

# OAuth (use test credentials)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Email Service (use test mode)
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=dev@chessarena.local

# Cloud Storage
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Application Configuration
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Rate Limiting (more lenient for development)
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=1000

# WebSocket Configuration
WS_PORT=3001
WS_PATH=/socket.io

# Logging
LOG_LEVEL=debug

# Approved College Domains
APPROVED_DOMAINS=edu,ac.uk,edu.au,test.com
