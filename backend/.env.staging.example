# Staging Environment Configuration
# Copy this file to .env.staging for staging deployment

# Database Configuration
DATABASE_URL=postgresql://user:password@staging-db-host:5432/chessarena_staging
REDIS_URL=redis://staging-redis-host:6379

# Authentication
JWT_SECRET=staging-secret-key-change-this
JWT_EXPIRATION=24h
REFRESH_TOKEN_EXPIRATION=30d

# OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://staging.chessarena.com/api/auth/google/callback

# Email Service
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@staging.chessarena.com

# Cloud Storage
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Application Configuration
NODE_ENV=staging
PORT=3001
FRONTEND_URL=https://staging.chessarena.com

# CORS Configuration
CORS_ORIGIN=https://staging.chessarena.com

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# WebSocket Configuration
WS_PORT=3001
WS_PATH=/socket.io

# Logging
LOG_LEVEL=info

# Approved College Domains
APPROVED_DOMAINS=edu,ac.uk,edu.au
