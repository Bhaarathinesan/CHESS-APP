# Production Environment Configuration
# Copy this file to .env.production for production deployment
# IMPORTANT: Use strong secrets and secure credentials

# Database Configuration
DATABASE_URL=postgresql://user:password@production-db-host:5432/chessarena
REDIS_URL=redis://production-redis-host:6379

# Authentication
JWT_SECRET=production-secret-key-use-strong-random-value
JWT_EXPIRATION=24h
REFRESH_TOKEN_EXPIRATION=30d

# OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://chessarena.com/api/auth/google/callback

# Email Service
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@chessarena.com

# Cloud Storage
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Application Configuration
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://chessarena.com

# CORS Configuration
CORS_ORIGIN=https://chessarena.com

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# WebSocket Configuration
WS_PORT=3001
WS_PATH=/socket.io

# Logging
LOG_LEVEL=warn

# Approved College Domains
APPROVED_DOMAINS=edu,ac.uk,edu.au

# Security
ENABLE_HTTPS=true
ENABLE_HELMET=true
