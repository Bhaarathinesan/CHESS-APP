generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String              @id @default(uuid()) @db.Uuid
  email                    String              @unique @db.VarChar(255)
  username                 String              @unique @db.VarChar(50)
  passwordHash             String?             @map("password_hash") @db.VarChar(255)
  displayName              String              @map("display_name") @db.VarChar(100)
  avatarUrl                String?             @map("avatar_url")
  bio                      String?
  country                  String?             @db.VarChar(100)
  city                     String?             @db.VarChar(100)
  collegeName              String              @map("college_name") @db.VarChar(255)
  collegeDomain            String              @map("college_domain") @db.VarChar(255)
  role                     UserRole            @default(PLAYER)
  emailVerified            Boolean             @default(false) @map("email_verified")
  emailVerificationToken   String?             @map("email_verification_token")
  passwordResetToken       String?             @map("password_reset_token")
  passwordResetExpires     DateTime?           @map("password_reset_expires") @db.Timestamp(6)
  twoFactorEnabled         Boolean             @default(false) @map("two_factor_enabled")
  twoFactorSecret          String?             @map("two_factor_secret") @db.VarChar(255)
  oauthProvider            String?             @map("oauth_provider") @db.VarChar(50)
  oauthId                  String?             @map("oauth_id") @db.VarChar(255)
  themePreference          String              @default("dark") @map("theme_preference") @db.VarChar(20)
  boardTheme               String              @default("default") @map("board_theme") @db.VarChar(50)
  pieceSet                 String              @default("default") @map("piece_set") @db.VarChar(50)
  soundEnabled             Boolean             @default(true) @map("sound_enabled")
  soundVolume              Int                 @default(70) @map("sound_volume")
  notificationPreferences  Json                @default("{}") @map("notification_preferences")
  chatEnabled              Boolean             @default(true) @map("chat_enabled")
  chatDisabledGames        String[]            @default([]) @map("chat_disabled_games")
  isOnline                 Boolean             @default(false) @map("is_online")
  lastOnline               DateTime?           @map("last_online") @db.Timestamp(6)
  isBanned                 Boolean             @default(false) @map("is_banned")
  banReason                String?             @map("ban_reason")
  banExpires               DateTime?           @map("ban_expires") @db.Timestamp(6)
  createdAt                DateTime            @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt                DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  chatMessages             ChatMessage[]
  following                Follow[]            @relation("Follower")
  followers                Follow[]            @relation("Following")
  blocking                 Block[]             @relation("Blocker")
  blockedBy                Block[]             @relation("Blocked")
  gamesAsBlack             Game[]              @relation("BlackPlayer")
  gamesAsWhite             Game[]              @relation("WhitePlayer")
  notifications            Notification[]
  ratingHistory            RatingHistory[]
  ratings                  Rating[]
  reportsReceived          Report[]            @relation("ReportedUser")
  reportsSubmitted         Report[]            @relation("Reporter")
  reportsReviewed          Report[]            @relation("Reviewer")
  pairingsAsBlack          TournamentPairing[] @relation("BlackPlayerPairing")
  pairingsAsWhite          TournamentPairing[] @relation("WhitePlayerPairing")
  tournamentParticipations TournamentPlayer[]
  tournamentAwards         TournamentAward[]
  tournamentsCreated       Tournament[]
  achievements             UserAchievement[]
  antiCheatFlags           AntiCheatFlag[]     @relation("AntiCheatFlagUser")
  antiCheatFlagsReviewed   AntiCheatFlag[]     @relation("AntiCheatFlagReviewer")
  bansReceived             UserBan[]           @relation("BannedUser")
  bansIssued               UserBan[]           @relation("BanIssuer")
  bansRevoked              UserBan[]           @relation("BanRevoker")

  @@index([email])
  @@index([username])
  @@index([collegeDomain])
  @@index([isOnline])
  @@index([oauthProvider, oauthId])
  @@map("users")
}

model Rating {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String      @map("user_id") @db.Uuid
  timeControl   TimeControl @map("time_control")
  rating        Int         @default(1200)
  peakRating    Int         @default(1200) @map("peak_rating")
  gamesPlayed   Int         @default(0) @map("games_played")
  wins          Int         @default(0)
  losses        Int         @default(0)
  draws         Int         @default(0)
  isProvisional Boolean     @default(true) @map("is_provisional")
  kFactor       Int         @default(40) @map("k_factor")
  updatedAt     DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, timeControl])
  @@index([userId])
  @@index([timeControl])
  @@index([timeControl, rating(sort: Desc)])
  @@map("ratings")
}

model RatingHistory {
  id           String      @id @default(uuid()) @db.Uuid
  userId       String      @map("user_id") @db.Uuid
  timeControl  TimeControl @map("time_control")
  ratingBefore Int         @map("rating_before")
  ratingAfter  Int         @map("rating_after")
  ratingChange Int         @map("rating_change")
  gameId       String?     @map("game_id") @db.Uuid
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamp(6)
  game         Game?       @relation(fields: [gameId], references: [id])
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([gameId])
  @@map("rating_history")
}

model Game {
  id                 String             @id @default(uuid()) @db.Uuid
  whitePlayerId      String             @map("white_player_id") @db.Uuid
  blackPlayerId      String             @map("black_player_id") @db.Uuid
  tournamentId       String?            @map("tournament_id") @db.Uuid
  timeControl        TimeControl        @map("time_control")
  initialTimeMinutes Int                @map("initial_time_minutes")
  incrementSeconds   Int                @map("increment_seconds")
  isRated            Boolean            @default(true) @map("is_rated")
  status             GameStatus         @default(PENDING)
  result             GameResult?
  terminationReason  String?            @map("termination_reason") @db.VarChar(50)
  pgn                String?
  fenCurrent         String             @default("rnbqkbnr/pppppppp/8/8/8/8/PPPPPPPP/RNBQKBNR w KQkq - 0 1") @map("fen_current") @db.VarChar(100)
  moveCount          Int                @default(0) @map("move_count")
  whiteTimeRemaining Int?               @map("white_time_remaining")
  blackTimeRemaining Int?               @map("black_time_remaining")
  whiteRatingBefore  Int?               @map("white_rating_before")
  blackRatingBefore  Int?               @map("black_rating_before")
  whiteRatingAfter   Int?               @map("white_rating_after")
  blackRatingAfter   Int?               @map("black_rating_after")
  openingName        String?            @map("opening_name") @db.VarChar(255)
  analysisData       Json?              @map("analysis_data")
  spectatorCount     Int                @default(0) @map("spectator_count")
  startedAt          DateTime?          @map("started_at") @db.Timestamp(6)
  completedAt        DateTime?          @map("completed_at") @db.Timestamp(6)
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt          DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  chatMessages       ChatMessage[]
  moves              GameMove[]
  blackPlayer        User               @relation("BlackPlayer", fields: [blackPlayerId], references: [id], onDelete: Cascade)
  tournament         Tournament?        @relation(fields: [tournamentId], references: [id])
  whitePlayer        User               @relation("WhitePlayer", fields: [whitePlayerId], references: [id], onDelete: Cascade)
  ratingHistory      RatingHistory[]
  tournamentPairing  TournamentPairing?
  antiCheatFlags     AntiCheatFlag[]    @relation("AntiCheatFlagGame")

  @@index([whitePlayerId, createdAt(sort: Desc)])
  @@index([blackPlayerId, createdAt(sort: Desc)])
  @@index([tournamentId])
  @@index([status])
  @@index([timeControl])
  @@index([createdAt(sort: Desc)])
  @@map("games")
}

model GameMove {
  id              String   @id @default(uuid()) @db.Uuid
  gameId          String   @map("game_id") @db.Uuid
  moveNumber      Int      @map("move_number")
  color           String   @db.VarChar(5)
  san             String   @db.VarChar(10)
  uci             String   @db.VarChar(10)
  fenAfter        String   @map("fen_after") @db.VarChar(100)
  timeTakenMs     Int      @map("time_taken_ms")
  timeRemainingMs Int      @map("time_remaining_ms")
  isCheck         Boolean  @default(false) @map("is_check")
  isCheckmate     Boolean  @default(false) @map("is_checkmate")
  isCapture       Boolean  @default(false) @map("is_capture")
  isCastling      Boolean  @default(false) @map("is_castling")
  isEnPassant     Boolean  @default(false) @map("is_en_passant")
  isPromotion     Boolean  @default(false) @map("is_promotion")
  promotionPiece  String?  @map("promotion_piece") @db.VarChar(10)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  game            Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, moveNumber, color])
  @@index([gameId, moveNumber])
  @@map("game_moves")
}

model Tournament {
  id                    String              @id @default(uuid()) @db.Uuid
  name                  String              @db.VarChar(255)
  description           String?
  bannerUrl             String?             @map("banner_url")
  creatorId             String              @map("creator_id") @db.Uuid
  format                TournamentFormat
  timeControl           TimeControl         @map("time_control")
  initialTimeMinutes    Int                 @map("initial_time_minutes")
  incrementSeconds      Int                 @map("increment_seconds")
  isRated               Boolean             @default(true) @map("is_rated")
  status                TournamentStatus    @default(CREATED)
  minPlayers            Int                 @default(4) @map("min_players")
  maxPlayers            Int                 @default(1000) @map("max_players")
  currentPlayers        Int                 @default(0) @map("current_players")
  roundsTotal           Int?                @map("rounds_total")
  roundsCompleted       Int                 @default(0) @map("rounds_completed")
  currentRound          Int                 @default(0) @map("current_round")
  pairingMethod         String              @default("automatic") @map("pairing_method") @db.VarChar(20)
  tiebreakCriteria      String              @default("buchholz") @map("tiebreak_criteria") @db.VarChar(50)
  allowLateRegistration Boolean             @default(false) @map("allow_late_registration")
  spectatorDelaySeconds Int                 @default(0) @map("spectator_delay_seconds")
  registrationDeadline  DateTime            @map("registration_deadline") @db.Timestamp(6)
  startTime             DateTime            @map("start_time") @db.Timestamp(6)
  endTime               DateTime?           @map("end_time") @db.Timestamp(6)
  shareLink             String?             @unique @map("share_link") @db.VarChar(255)
  qrCodeUrl             String?             @map("qr_code_url")
  prizeDescription      String?             @map("prize_description")
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt             DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  games                 Game[]
  pairings              TournamentPairing[]
  players               TournamentPlayer[]
  awards                TournamentAward[]
  creator               User                @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
  @@index([status])
  @@index([startTime])
  @@index([shareLink])
  @@map("tournaments")
}

model TournamentPlayer {
  id             String     @id @default(uuid()) @db.Uuid
  tournamentId   String     @map("tournament_id") @db.Uuid
  userId         String     @map("user_id") @db.Uuid
  score          Decimal    @default(0.0) @db.Decimal(4, 1)
  wins           Int        @default(0)
  losses         Int        @default(0)
  draws          Int        @default(0)
  buchholzScore  Decimal    @default(0.0) @map("buchholz_score") @db.Decimal(6, 2)
  sonneborBerger Decimal    @default(0.0) @map("sonneborn_berger") @db.Decimal(6, 2)
  rank           Int?
  isActive       Boolean    @default(true) @map("is_active")
  hasBye         Boolean    @default(false) @map("has_bye")
  joinedAt       DateTime   @default(now()) @map("joined_at") @db.Timestamp(6)
  tournament     Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@index([tournamentId, score(sort: Desc)])
  @@index([userId])
  @@map("tournament_players")
}

model TournamentAward {
  id               String     @id @default(uuid()) @db.Uuid
  tournamentId     String     @map("tournament_id") @db.Uuid
  userId           String     @map("user_id") @db.Uuid
  placement        Int
  awardTitle       String     @map("award_title") @db.VarChar(100)
  awardDescription String?    @map("award_description")
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  tournament       Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@index([userId])
  @@map("tournament_awards")
}

model TournamentPairing {
  id            String         @id @default(uuid()) @db.Uuid
  tournamentId  String         @map("tournament_id") @db.Uuid
  roundNumber   Int            @map("round_number")
  whitePlayerId String?        @map("white_player_id") @db.Uuid
  blackPlayerId String?        @map("black_player_id") @db.Uuid
  gameId        String?        @unique @map("game_id") @db.Uuid
  result        PairingResult?
  boardNumber   Int?           @map("board_number")
  isBye         Boolean        @default(false) @map("is_bye")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamp(6)
  blackPlayer   User?          @relation("BlackPlayerPairing", fields: [blackPlayerId], references: [id], onDelete: Cascade)
  game          Game?          @relation(fields: [gameId], references: [id])
  tournament    Tournament     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  whitePlayer   User?          @relation("WhitePlayerPairing", fields: [whitePlayerId], references: [id], onDelete: Cascade)

  @@index([tournamentId, roundNumber])
  @@index([whitePlayerId, blackPlayerId])
  @@index([gameId])
  @@map("tournament_pairings")
}

model Achievement {
  id               String            @id @default(uuid()) @db.Uuid
  code             String            @unique @db.VarChar(50)
  name             String            @db.VarChar(100)
  description      String
  iconUrl          String?           @map("icon_url")
  category         String            @db.VarChar(30)
  points           Int               @default(0)
  isHidden         Boolean           @default(false) @map("is_hidden")
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamp(6)
  userAchievements UserAchievement[]

  @@index([code])
  @@index([category])
  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String      @map("user_id") @db.Uuid
  achievementId String      @map("achievement_id") @db.Uuid
  earnedAt      DateTime    @default(now()) @map("earned_at") @db.Timestamp(6)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId, earnedAt(sort: Desc)])
  @@index([achievementId])
  @@map("user_achievements")
}

model Notification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  type      String    @db.VarChar(50)
  title     String    @db.VarChar(255)
  message   String
  data      Json      @default("{}")
  isRead    Boolean   @default(false) @map("is_read")
  linkUrl   String?   @map("link_url")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  readAt    DateTime? @map("read_at") @db.Timestamp(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isRead], where: raw("(is_read = false)"))
  @@map("notifications")
}

model Follow {
  id          String   @id @default(uuid()) @db.Uuid
  followerId  String   @map("follower_id") @db.Uuid
  followingId String   @map("following_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model Block {
  id        String   @id @default(uuid()) @db.Uuid
  blockerId String   @map("blocker_id") @db.Uuid
  blockedId String   @map("blocked_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("blocks")
}

model Report {
  id             String       @id @default(uuid()) @db.Uuid
  reporterId     String       @map("reporter_id") @db.Uuid
  reportedUserId String?      @map("reported_user_id") @db.Uuid
  gameId         String?      @map("game_id") @db.Uuid
  reportType     String       @map("report_type") @db.VarChar(30)
  description    String
  status         ReportStatus @default(PENDING)
  adminNotes     String?      @map("admin_notes")
  reviewedBy     String?      @map("reviewed_by") @db.Uuid
  reviewedAt     DateTime?    @map("reviewed_at") @db.Timestamp(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  reportedUser   User?        @relation("ReportedUser", fields: [reportedUserId], references: [id], onDelete: Cascade)
  reporter       User         @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewer       User?        @relation("Reviewer", fields: [reviewedBy], references: [id])

  @@index([reporterId])
  @@index([reportedUserId])
  @@index([status])
  @@map("reports")
}

model ChatMessage {
  id          String       @id @default(uuid()) @db.Uuid
  gameId      String       @map("game_id") @db.Uuid
  senderId    String       @map("sender_id") @db.Uuid
  message     String
  isSpectator Boolean      @default(false) @map("is_spectator")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  game        Game         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  sender      User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  reports     ChatReport[]

  @@index([gameId, createdAt])
  @@index([senderId])
  @@map("chat_messages")
}

model ChatReport {
  id          String      @id @default(uuid()) @db.Uuid
  messageId   String      @map("message_id") @db.Uuid
  reporterId  String      @map("reporter_id") @db.Uuid
  reason      String
  status      String      @default("pending") @db.VarChar(20)
  reviewedBy  String?     @map("reviewed_by") @db.Uuid
  reviewedAt  DateTime?   @map("reviewed_at") @db.Timestamp(6)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamp(6)
  message     ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([reporterId])
  @@index([status])
  @@map("chat_reports")
}

enum UserRole {
  SUPER_ADMIN      @map("super_admin")
  TOURNAMENT_ADMIN @map("tournament_admin")
  PLAYER           @map("player")
  SPECTATOR        @map("spectator")

  @@map("user_role")
}

enum TimeControl {
  BULLET    @map("bullet")
  BLITZ     @map("blitz")
  RAPID     @map("rapid")
  CLASSICAL @map("classical")

  @@map("time_control")
}

enum GameStatus {
  PENDING   @map("pending")
  ACTIVE    @map("active")
  COMPLETED @map("completed")
  ABORTED   @map("aborted")

  @@map("game_status")
}

enum GameResult {
  WHITE_WIN @map("white_win")
  BLACK_WIN @map("black_win")
  DRAW      @map("draw")

  @@map("game_result")
}

enum TournamentFormat {
  SWISS              @map("swiss")
  ROUND_ROBIN        @map("round_robin")
  SINGLE_ELIMINATION @map("single_elimination")
  DOUBLE_ELIMINATION @map("double_elimination")
  ARENA              @map("arena")

  @@map("tournament_format")
}

enum TournamentStatus {
  CREATED             @map("created")
  REGISTRATION_OPEN   @map("registration_open")
  REGISTRATION_CLOSED @map("registration_closed")
  IN_PROGRESS         @map("in_progress")
  ROUND_IN_PROGRESS   @map("round_in_progress")
  ROUND_COMPLETED     @map("round_completed")
  COMPLETED           @map("completed")
  CANCELLED           @map("cancelled")

  @@map("tournament_status")
}

enum PairingResult {
  WHITE_WIN @map("white_win")
  BLACK_WIN @map("black_win")
  DRAW      @map("draw")
  BYE       @map("bye")

  @@map("pairing_result")
}

enum ReportStatus {
  PENDING   @map("pending")
  REVIEWED  @map("reviewed")
  RESOLVED  @map("resolved")
  DISMISSED @map("dismissed")

  @@map("report_status")
}

model CollegeDomain {
  id          String   @id @default(uuid()) @db.Uuid
  domain      String   @unique @db.VarChar(255)
  collegeName String   @map("college_name") @db.VarChar(255)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@index([isActive])
  @@map("college_domains")
}

model AntiCheatFlag {
  id         String              @id @default(uuid()) @db.Uuid
  userId     String              @map("user_id") @db.Uuid
  gameId     String?             @map("game_id") @db.Uuid
  flagType   AntiCheatFlagType   @map("flag_type")
  severity   Int                 @default(1)
  details    Json                @default("{}")
  status     AntiCheatFlagStatus @default(PENDING)
  reviewedBy String?             @map("reviewed_by") @db.Uuid
  reviewedAt DateTime?           @map("reviewed_at") @db.Timestamp(6)
  adminNotes String?             @map("admin_notes")
  createdAt  DateTime            @default(now()) @map("created_at") @db.Timestamp(6)
  user       User                @relation("AntiCheatFlagUser", fields: [userId], references: [id], onDelete: Cascade)
  game       Game?               @relation("AntiCheatFlagGame", fields: [gameId], references: [id], onDelete: SetNull)
  reviewer   User?               @relation("AntiCheatFlagReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([gameId])
  @@index([status])
  @@index([flagType])
  @@index([createdAt(sort: Desc)])
  @@map("anti_cheat_flags")
}

enum AntiCheatFlagType {
  FAST_MOVES          @map("fast_moves")
  TAB_FOCUS_LOSS      @map("tab_focus_loss")
  BROWSER_EXTENSION   @map("browser_extension")
  STATISTICAL_ANOMALY @map("statistical_anomaly")

  @@map("anti_cheat_flag_type")
}

enum AntiCheatFlagStatus {
  PENDING   @map("pending")
  REVIEWED  @map("reviewed")
  CONFIRMED @map("confirmed")
  DISMISSED @map("dismissed")

  @@map("anti_cheat_flag_status")
}

model UserBan {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  banType      BanType  @map("ban_type")
  reason       String
  expiresAt    DateTime? @map("expires_at") @db.Timestamp(6)
  issuedBy     String   @map("issued_by") @db.Uuid
  issuedAt     DateTime @default(now()) @map("issued_at") @db.Timestamp(6)
  revokedAt    DateTime? @map("revoked_at") @db.Timestamp(6)
  revokedBy    String?  @map("revoked_by") @db.Uuid
  revokeReason String?  @map("revoke_reason")
  isActive     Boolean  @default(true) @map("is_active")
  user         User     @relation("BannedUser", fields: [userId], references: [id], onDelete: Cascade)
  issuer       User     @relation("BanIssuer", fields: [issuedBy], references: [id], onDelete: Restrict)
  revoker      User?    @relation("BanRevoker", fields: [revokedBy], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([issuedBy])
  @@index([isActive])
  @@index([issuedAt(sort: Desc)])
  @@map("user_bans")
}

enum BanType {
  WARNING    @map("warning")
  TEMPORARY  @map("temporary")
  PERMANENT  @map("permanent")

  @@map("ban_type")
}

model Announcement {
  id        String              @id @default(uuid()) @db.Uuid
  title     String              @db.VarChar(255)
  message   String
  priority  AnnouncementPriority @default(NORMAL)
  linkUrl   String?             @map("link_url")
  createdBy String              @map("created_by") @db.Uuid
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamp(6)
  expiresAt DateTime?           @map("expires_at") @db.Timestamp(6)
  isActive  Boolean             @default(true) @map("is_active")

  @@index([createdAt(sort: Desc)])
  @@index([isActive])
  @@index([priority])
  @@map("announcements")
}

enum AnnouncementPriority {
  LOW      @map("low")
  NORMAL   @map("normal")
  HIGH     @map("high")
  URGENT   @map("urgent")

  @@map("announcement_priority")
}

model SystemLog {
  id          String    @id @default(uuid()) @db.Uuid
  level       LogLevel
  message     String
  context     String?   @db.VarChar(255)
  metadata    Json?
  stackTrace  String?   @map("stack_trace")
  userId      String?   @map("user_id") @db.Uuid
  ipAddress   String?   @map("ip_address") @db.VarChar(45)
  userAgent   String?   @map("user_agent")
  method      String?   @db.VarChar(10)
  url         String?
  statusCode  Int?      @map("status_code")
  responseTime Int?     @map("response_time")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)

  @@index([level])
  @@index([createdAt(sort: Desc)])
  @@index([userId])
  @@index([context])
  @@map("system_logs")
}

enum LogLevel {
  ERROR   @map("error")
  WARN    @map("warn")
  INFO    @map("info")
  DEBUG   @map("debug")

  @@map("log_level")
}
